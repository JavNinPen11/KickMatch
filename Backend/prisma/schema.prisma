generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum para el estado de los partidos
enum EstadoPartido {
  abierto
  completo
  cancelado
  finalizado
}

model Rol {
  id          Int     @id @default(autoincrement()) @map("id_rol")
  nombre      String  @db.VarChar(50)
  descripcion String? @db.Text

  usuarios User[] @relation("RolUsuario")
}

model User {
  id       Int      @id @default(autoincrement()) @map("id_usuario")
  nombre   String   @default("Sin nombre") @db.VarChar(100)
  email    String   @unique @db.VarChar(150)
  username String   @unique @default("No") @db.VarChar(50)
  password String   @db.VarChar(255)
  rolId    Int?     @default(2) @map("rol_id")
  rol      Rol?     @relation("RolUsuario", fields: [rolId], references: [id])
  creadoEn DateTime @default(now()) @map("creado_en")

  partidosCreados Match[]            @relation("CreadorPartido")
  partidosUnidos  MatchParticipant[]
}

model Equipo {
  id     Int     @id @default(autoincrement()) @map("id_equipo")
  nombre String  @db.VarChar(100)
  logo   String? @db.VarChar(255)
  color  String? @db.VarChar(20)
}

model Match {
  id           Int                @id @default(autoincrement())
  date         DateTime
  time         DateTime           @db.Time
  location     String?            @db.VarChar(255)
  maxPlayers   Int?
  state        EstadoPartido      @default(abierto)
  creatorId    Int
  creator      User               @relation("CreadorPartido", fields: [creatorId], references: [id])
  createdAt    DateTime           @default(now())
  participants MatchParticipant[]
}

model MatchParticipant {
  id      Int   @id @default(autoincrement())
  matchId Int
  userId  Int
  match   Match @relation(fields: [matchId], references: [id])
  user    User  @relation(fields: [userId], references: [id])

  @@unique([matchId, userId]) // un usuario no puede apuntarse dos veces
}
