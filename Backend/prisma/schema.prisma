generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum para el estado de los partidos
enum EstadoPartido {
  abierto
  completo
  cancelado
  finalizado
}

model Rol {
  id          Int     @id @default(autoincrement()) @map("id_rol")
  nombre      String  @db.VarChar(50)
  descripcion String? @db.Text

  usuarios User[] @relation("RolUsuario")
}

model User {
  id       Int      @id @default(autoincrement()) @map("id_usuario")
  nombre   String   @default("Sin nombre") @db.VarChar(100)
  email    String   @unique @db.VarChar(150)
  username String   @unique @default("No") @db.VarChar(50)
  password String   @db.VarChar(255)
  rolId    Int?     @default(2) @map("rol_id")
  rol      Rol?     @relation("RolUsuario", fields: [rolId], references: [id])
  creadoEn DateTime @default(now()) @map("creado_en")

  partidosCreados Match[]            @relation("CreadorPartido")
  partidosUnidos  MatchParticipant[]
  reservas Reserva[]
}

model Equipo {
  id     Int     @id @default(autoincrement()) @map("id_equipo")
  nombre String  @db.VarChar(100)
  logo   String? @db.VarChar(255)
  color  String? @db.VarChar(20)
}

model Match {
  id           Int                @id @default(autoincrement())
  date         DateTime
  time         DateTime           @db.Time
  location     String?            @db.VarChar(255)
  maxPlayers   Int?
  state        EstadoPartido      @default(abierto)
  creatorId    Int
  creator      User               @relation("CreadorPartido", fields: [creatorId], references: [id])
  createdAt    DateTime           @default(now())
  participants MatchParticipant[]
}

model MatchParticipant {
  id      Int   @id @default(autoincrement())
  matchId Int
  userId  Int
  match   Match @relation(fields: [matchId], references: [id])
  user    User  @relation(fields: [userId], references: [id])

  @@unique([matchId, userId]) // un usuario no puede apuntarse dos veces
}
model FieldCategory {
  id          Int     @id @default(autoincrement())
  nombre      String  @db.VarChar(100)
  descripcion String? @db.Text

  campos Field[]
}

model Field {
  id          Int            @id @default(autoincrement())
  nombre      String         @db.VarChar(100)
  descripcion String?        @db.Text
  precio      Decimal        @db.Decimal(10, 2)
  imagen      String?        @db.VarChar(255)
  escaparate  Boolean        @default(false)
  categoryId  Int
  category    FieldCategory  @relation(fields: [categoryId], references: [id])
  creadoEn    DateTime       @default(now())

  reservas ReservaLinea[]
}

model Reserva {
  id          Int            @id @default(autoincrement())
  userId      Int
  user        User           @relation(fields: [userId], references: [id])
  estado      EstadoReserva  @default(pendiente)
  creadoEn    DateTime       @default(now())
  confirmadoEn DateTime?

  lineas ReservaLinea[]
}

model ReservaLinea {
  id        Int      @id @default(autoincrement())
  reservaId Int
  reserva   Reserva  @relation(fields: [reservaId], references: [id])
  fieldId   Int
  field     Field    @relation(fields: [fieldId], references: [id])
  fecha     DateTime
  horaInicio String  @db.VarChar(5)
  horaFin    String  @db.VarChar(5)
  cantidad  Int      @default(1)
  precio    Decimal  @db.Decimal(10, 2)
}

enum EstadoReserva {
  pendiente
  confirmada
  cancelada
}